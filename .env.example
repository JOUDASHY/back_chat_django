# Database settings
DB_NAME=chatdb
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=3306

# Pusher settings
PUSHER_APP_ID=your_pusher_app_id
PUSHER_KEY=your_pusher_key
PUSHER_SECRET=your_pusher_secret
PUSHER_CLUSTER=your_pusher_cluster

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_secret

# Email settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_email_app_password
EMAIL_USE_TLS=True

# Frontend / Backend URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Optional: extra CORS origins (comma-separated), e.g. Vercel production URL
# CORS_ALLOWED_ORIGINS=https://chat-beast.vercel.app,http://localhost:3000

# Hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# LiveKit (appels audio/vidéo — voir docs/LIVEKIT_VPS_LINUX.md)
LIVEKIT_URL=wss://livekit.votredomaine.com
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
